<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client action that loads the OWL dashboard component -->
    <record id="action_accounting_dashboard" model="ir.actions.client">
        <field name="name">Accounting Dashboard</field>
        <field name="tag">accounting_dashboard</field>
    </record>

    <!-- Root application menu -->
    <menuitem id="menu_accounting_dashboard_root"
              name="Accounting Dashboard"
              sequence="10"
              web_icon="accounting_dashboard,static/description/icon.png"/>

    <!-- Dashboard menu (opens the client action) -->
    <menuitem id="menu_accounting_dashboard_main"
              name="Dashboard"
              parent="menu_accounting_dashboard_root"
              action="action_accounting_dashboard"
              sequence="1"/>

    <!-- Configuration sub-menu -->
    <menuitem id="menu_accounting_dashboard_config"
              name="Configuration"
              parent="menu_accounting_dashboard_root"
              sequence="90"/>

    <menuitem id="menu_dashboard_expense_entries"
              name="Expense Entries"
              parent="menu_accounting_dashboard_config"
              action="action_dashboard_expense"
              sequence="10"/>
</odoo>

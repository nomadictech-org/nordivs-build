<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="employee_api_pin_wizard_form" model="ir.ui.view">
        <field name="name">employee.api.pin.wizard.form</field>
        <field name="model">employee.api.pin.wizard</field>
        <field name="arch" type="xml">
            <form string="Set Mobile PIN">
                <group>
                    <field name="employee_id"/>
                    <field name="new_pin" password="True"/>
                    <field name="confirm_pin" password="True"/>
                    <field name="auto_enable"/>
                </group>
                <footer>
                    <button name="action_set_pin"
                            string="Set PIN"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>

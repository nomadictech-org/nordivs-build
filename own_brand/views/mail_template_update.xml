<?xml version="1.0" encoding="utf-8"?>
<!--
    mail_template_update.xml
    ========================
    WHY THE ORIGINAL APPROACH FAILED:
        Using <record id="crm.mail_template_demo_crm_lead"> tries to update a
        record owned by the "crm" module. Odoo validates the external ID at parse
        time and raises:
            AssertionError: The ID "crm.mail_template_demo_crm_lead"
                            refers to an uninstalled module
        This happens in Community when demo data is not loaded or the xml_id is
        missing. Enterprise happens to load it, hiding the bug.

    CORRECT APPROACH:
        Template patching is handled in hooks.py via post_init_hook /
        post_migrate_hook so it runs AFTER all modules are loaded, safely
        handles missing records, and works in both Community and Enterprise.
-->
<odoo>
    <data>
        <!-- Patching is done via post_init_hook in hooks.py -->
    </data>
</odoo>
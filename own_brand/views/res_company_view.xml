<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_company_form_ownbrand" model="ir.ui.view">
        <field name="name">res.company.form.ownbrand</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <!-- Add a dedicated page to the company form's notebook. -->
            <xpath expr="//notebook" position="inside">
                <page string="Dashboard Background" name="ownbrand_background">
                    <group>
                        <group string="Background">
                            <field name="ownbrand_bg_type"/>
                            <field name="ownbrand_bg_color_1"
                                   widget="color"
                                   invisible="ownbrand_bg_type == 'image'"/>
                            <field name="ownbrand_bg_color_2"
                                   widget="color"
                                   invisible="ownbrand_bg_type != 'gradient'"/>
                            <field name="ownbrand_bg_angle"
                                   invisible="ownbrand_bg_type != 'gradient'"/>
                            <field name="ownbrand_bg_image"
                                   widget="image"
                                   invisible="ownbrand_bg_type != 'image'"/>
                        </group>
                        <group>
                            <div class="text-muted" colspan="2">
                                This background is applied to the Home Menu
                                (app dashboard) for this company. Choose a
                                gradient (two colors + angle), a single solid
                                color, or upload an image. Refresh the page
                                after saving to see the change.
                            </div>
                        </group>
                    </group>
                </page>
                <page string="Report Branding" name="ownbrand_report_branding">
                    <group>
                        <group string="Header">
                            <field name="report_header_image"
                                   widget="image"
                                   options="{'size': [800, 150]}"/>
                        </group>
                        <group string="Footer">
                            <field name="report_footer_image"
                                   widget="image"
                                   options="{'size': [800, 150]}"/>
                        </group>
                    </group>
                    <group>
                        <div class="text-muted" colspan="2">
                            Upload images to use as the header and footer of
                            every printed report (PDF). The images stretch to
                            full page width and appear in addition to Odoo's
                            standard header/footer. Leave a field empty to
                            keep only the default Odoo content. Recommended
                            sizes: ~1654px wide for A4 paper, with a height
                            of 100-180px for a clean banner look.
                        </div>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

</odoo>